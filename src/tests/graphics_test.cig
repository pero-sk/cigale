import stdl.graphics { window, draw };
import stdl.console { cout };
func public d() {
    cout("Hello!");
    draw.clear([30, 30, 30, 255]);
    /" background grid "/
    int i = 0;
    while (i < 800) {
        draw.line(i, 0, i, 600, [50, 50, 50, 255]);
        i += 50;
    }
    int j = 0;
    while (j < 600) {
        draw.line(0, j, 800, j, [50, 50, 50, 255]);
        j += 50;
    }

    /" red rectangle "/
    draw.rect(50, 50, 200, 150, [220, 50, 50, 255]);

    /" green circle "/
    draw.circle(400, 300, 80, [50, 220, 50, 255]);

    /" blue rectangle "/
    draw.rect(550, 400, 150, 100, [50, 50, 220, 255]);

    /" white diagonal lines "/
    draw.line(0, 0, 800, 600, [255, 255, 255, 255]);
    draw.line(800, 0, 0, 600, [255, 255, 255, 255]);

    /" yellow circle in corner "/
    draw.circle(700, 100, 40, [220, 220, 50, 255]);
}

func public static main() {
    window win = window();
    win.create(800, 600, "Cigale Graphics Test");
    win.event.on("draw", d);

    win.run();
}